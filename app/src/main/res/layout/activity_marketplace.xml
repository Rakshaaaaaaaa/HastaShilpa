<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F1F8E9"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Direct Marketplace"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:paddingBottom="8dp"
        android:paddingTop="10dp"/>

    <TextView
        android:id="@+id/tvListedCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Listed: 0 products"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:padding="10dp"
        android:background="#6A1B9A"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etProductName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Product name"
        android:textColor="#333333"
        android:backgroundTint="#2E7D32"
        android:inputType="text"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etProductDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Description"
        android:textColor="#333333"
        android:backgroundTint="#2E7D32"
        android:inputType="text"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etProductPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Price (Rs)"
        android:textColor="#333333"
        android:backgroundTint="#2E7D32"
        android:inputType="numberDecimal"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etProductMaterial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Material used e.g. Bamboo"
        android:textColor="#333333"
        android:backgroundTint="#2E7D32"
        android:inputType="text"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etProductDimensions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Dimensions e.g. 30cm x 20cm"
        android:textColor="#333333"
        android:backgroundTint="#2E7D32"
        android:inputType="text"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etHoursWorked"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Hours worked"
        android:textColor="#333333"
        android:backgroundTint="#2E7D32"
        android:inputType="numberDecimal"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnAddProduct"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Add Product"
        android:textSize="16sp"
        android:backgroundTint="#6A1B9A"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvNoProducts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No products added yet!"
        android:textSize="14sp"
        android:textColor="#888888"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMarketplace"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>