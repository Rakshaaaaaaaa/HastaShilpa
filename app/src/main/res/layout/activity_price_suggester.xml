<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Price Suggester"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:paddingBottom="16dp"
            android:paddingTop="10dp"/>

        <EditText
            android:id="@+id/etMaterialCost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Total material cost (Rs)"
            android:textColor="#333333"
            android:backgroundTint="#2E7D32"
            android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etHoursWorked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Hours worked"
            android:textColor="#333333"
            android:backgroundTint="#2E7D32"
            android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etHourlyRate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Hourly rate (Rs) default 50"
            android:textColor="#333333"
            android:backgroundTint="#2E7D32"
            android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etProfitMargin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Profit margin % default 30"
            android:textColor="#333333"
            android:backgroundTint="#2E7D32"
            android:inputType="numberDecimal"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnCalculatePrice"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Calculate Price"
            android:textSize="16sp"
            android:backgroundTint="#F57F17"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvMaterialCostResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#333333"
            android:padding="8dp"
            android:background="#C8E6C9"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvLaborCostResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#333333"
            android:padding="8dp"
            android:background="#DCEDC8"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvBaseCostResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#333333"
            android:padding="8dp"
            android:background="#F0F4C3"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvProfitResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:padding="8dp"
            android:background="#E65100"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvSuggestedPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:padding="16dp"
            android:background="#2E7D32"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvMinPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:padding="8dp"
            android:background="#B71C1C"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvMaxPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:padding="8dp"
            android:background="#1565C0"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>