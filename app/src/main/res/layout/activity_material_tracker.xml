<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F1F8E9"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Material Tracker"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:paddingBottom="8dp"
        android:paddingTop="10dp"/>

    <TextView
        android:id="@+id/tvTotalCost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total Material Cost: Rs 0.00"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:padding="10dp"
        android:background="#E65100"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etMaterialName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Material name e.g. Bamboo poles"
        android:textColor="#333333"
        android:backgroundTint="#2E7D32"
        android:inputType="text"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etMaterialQty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Quantity e.g. 10"
        android:textColor="#333333"
        android:backgroundTint="#2E7D32"
        android:inputType="numberDecimal"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etMaterialUnit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Unit e.g. pieces, kg, meters"
        android:textColor="#333333"
        android:backgroundTint="#2E7D32"
        android:inputType="text"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etMaterialCost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Cost per unit (Rs)"
        android:textColor="#333333"
        android:backgroundTint="#2E7D32"
        android:inputType="numberDecimal"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etBatchName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Batch name (optional)"
        android:textColor="#333333"
        android:backgroundTint="#2E7D32"
        android:inputType="text"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnAddMaterial"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Log Material"
        android:textSize="16sp"
        android:backgroundTint="#E65100"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvNoMaterials"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No materials logged yet!"
        android:textSize="14sp"
        android:textColor="#888888"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMaterials"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>